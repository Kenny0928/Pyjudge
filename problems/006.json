{
  "id": 6,
  "title": "反轉字串",
  "difficulty": "Easy",
  "tags": ["字串"],
  "description": "<p>給定一個字串 <code>S</code>，請將其反轉後輸出。</p><p>字串只包含英文字母和數字，不含空格。</p>",
  "inputFormat": "<p>一行，包含字串 <code>S</code>。</p>",
  "outputFormat": "<p>一行，輸出反轉後的字串。</p>",
  "constraints": "<ul><li>1 ≤ |S| ≤ 10<sup>5</sup></li></ul>",
  "timeLimit": 1,
  "memoryLimit": 256,
  "sampleInput": "hello",
  "sampleOutput": "olleh",
  "testCases": [
    { "input": "hello",       "output": "olleh"       },
    { "input": "12345",       "output": "54321"       },
    { "input": "a",           "output": "a"           },
    { "input": "abcdefghij",  "output": "jihgfedcba"  },
    { "input": "PyJudge2025", "output": "5202eguJyP"  }
  ]
}
